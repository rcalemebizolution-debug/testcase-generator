GROQ_API_KEY=
AI_ACCESS_CODE=
# Optional: defaults to openai/gpt-oss-120b
GROQ_MODEL=

# Optional Supabase backend. When both are set, Casecraft uses Supabase Auth
# and the public.profiles table from supabase/schema.sql for shared users.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Alternative fallback if your hosting provider blocks/hides variables containing KEY.
VITE_SUPABASE_PUBLIC_ANON_KEY=
