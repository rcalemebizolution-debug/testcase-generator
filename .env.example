# Local-only server-side AI configuration. Copy to .env.local and set real values.
# Never expose these values in VITE_* variables or commit .env.local.
GROQ_API_KEY=
AI_ACCESS_CODE=
# Set this to a Groq model ID that supports image input.
GROQ_VISION_MODEL=
# Optional text-only model for requests without screenshots.
GROQ_MODEL=
